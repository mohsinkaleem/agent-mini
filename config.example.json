{
  "provider": "ollama",
  "providers": {
    "ollama": {
      "baseUrl": "http://localhost:11434",
      "model": "llama3.1",
      "think": false
    },
    "gemini": {
      "apiKey": "",
      "model": "gemini-2.0-flash"
    },
    "github_copilot": {
      "token": "",
      "model": "gpt-4o"
    },
    "local": {
      "baseUrl": "http://localhost:8080/v1",
      "apiKey": "no-key",
      "model": "local-model"
    }
  },
  "agent": {
    "maxIterations": 20,
    "temperature": 0.7,
    "systemPrompt": ""
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "",
      "allowFrom": [],
      "streamResponses": true
    }
  },
  "tools": {
    "restrictToWorkspace": false
  },
  "memory": {
    "enabled": true,
    "maxEntries": 1000
  },
  "workspace": "~/.agent-mini/workspace"
}
